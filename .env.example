# Copy to .env and fill in real values from console.aiven.io (.env is gitignored).
# Used two ways:
#   - Local run against Aiven:  docker run --env-file .env -e SPRING_PROFILES_ACTIVE=prod ...
#   - Reference for the values you paste into the Render dashboard (see render.yaml keys).
#
# Where to find each value in the Aiven console: open the service -> "Connection information".

SPRING_PROFILES_ACTIVE=prod

# --- Aiven MySQL (Service -> Connection information) ---
MYSQL_HOST=CHANGE_ME.aivencloud.com
MYSQL_PORT=CHANGE_ME            # e.g. 12345 (NOT 3306)
MYSQL_DATABASE=defaultdb
MYSQL_USERNAME=avnadmin
MYSQL_PASSWORD=CHANGE_ME

# --- Aiven Valkey / Redis (Service -> Connection information) ---
REDIS_HOST=CHANGE_ME.aivencloud.com
REDIS_PORT=CHANGE_ME            # e.g. 12346
REDIS_USERNAME=default
REDIS_PASSWORD=CHANGE_ME

# --- Aiven Kafka (enable SASL first, then Service -> Connection information -> SASL) ---
KAFKA_BOOTSTRAP_SERVERS=CHANGE_ME.aivencloud.com:12347
KAFKA_USERNAME=avnadmin
KAFKA_PASSWORD=CHANGE_ME

# --- Shared Aiven project CA (one CA covers all three services) ---
# Download "CA Certificate" from any service page. When using --env-file, put the whole PEM on one
# line with literal \n between lines, OR pass it inline instead:
#   -e AIVEN_CA_CERT="$(cat ca.pem)"
# On Render, paste the multi-line PEM directly into the AIVEN_CA_CERT env var.
AIVEN_CA_CERT=
# Optional: where the entrypoint writes the CA inside the container (default shown).
AIVEN_CA_PATH=/tmp/aiven-ca.pem

# --- Public base URL for returned short links (set to your Render URL after first deploy) ---
APP_BASE_URL=http://localhost:8080
