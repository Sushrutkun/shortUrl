    {
      "id": "Avw4eGSGMjHT_gpPF_P1A",
      "type": "text",
      "x": 1193.7152119067327,
      "y": 10010.60556217888,
      "width": 58.879974365234375,
      "height": 25,
      "angle": 0,
      "strokeColor": "#e03131",
