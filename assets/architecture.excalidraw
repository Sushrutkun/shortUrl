      "isDeleted": false,
      "boundElements": [],
      "updated": 1783176303853,
      "link": null,
      "locked": false,
      "text": "GET -> will read from db for 1st time then from redis\nPOST -> will store mapping to db \nPUT -> will update mapping to db also delete the cache \nDELETE -> soft delete the mapping delete the cache\n\n",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "GET -> will read from db for 1st time then from redis\nPOST -> will store mapping to db \nPUT -> will update mapping to db also delete the cache \nDELETE -> soft delete the mapping delete the cache\n\n",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "hk8r97BK3JQ88LPnn4rnl",
      "type": "text",
      "x": 2273.240495582641,
      "y": 10135.254220915902,
      "width": 618.4595336914062,
      "height": 75,
      "angle": 0,
      "strokeColor": "#e03131",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b9f",
      "roundness": null,
      "seed": 1191229354,
      "version": 548,
      "versionNonce": 683883562,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1783177185209,
      "link": null,
      "locked": false,
      "text": "Analytics -> will add a kafka layer whenever we get the get call\n                my consumer will pick it and update the \n                click count in db",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Analytics -> will add a kafka layer whenever we get the get call\n                my consumer will pick it and update the \n                click count in db",
      "autoResize": true,
      "lineHeight": 1.25
    },
