      "link": null,
      "locked": false,
      "text": "Push msg in redis with a set sorted in asc order \nIn service there will be a scheduler which will poll all delay msgs in 1sec\nif any gets < current_time in th redis set \nremove that from redis \nagain mark the run status as running with delay response as true\nin another case if any event value /signal is true but still in dealy \nneed to remove that too\n",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Push msg in redis with a set sorted in asc order \nIn service there will be a scheduler which will poll all delay msgs in 1sec\nif any gets < current_time in th redis set \nremove that from redis \nagain mark the run status as running with delay response as true\nin another case if any event value /signal is true but still in dealy \nneed to remove that too\n",
      "autoResize": true,
      "lineHeight": 1.25
