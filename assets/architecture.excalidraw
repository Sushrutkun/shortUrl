    {
      "id": "BHCQu_kCzuhQR8POt_F7B",
      "type": "text",
      "x": 2269.3564373114095,
      "y": 9985.070634428283,
      "width": 552.459716796875,
      "height": 150,
      "angle": 0,
      "strokeColor": "#e03131",
      "backgroundColor": "transparent",
