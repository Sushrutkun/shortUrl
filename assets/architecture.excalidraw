      "boundElements": [],
      "updated": 1783244412215,
      "link": null,
      "locked": false,
      "text": "Assumptions\n    1.  Single Entry Trigger & multiple Exit Triggers\n    2. Workflow will alwaysend at a Action/Wait node\n    3. Considered multiple runs can happen for a single workflow\n        and are in higher throughput..\n",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Assumptions\n    1.  Single Entry Trigger & multiple Exit Triggers\n    2. Workflow will alwaysend at a Action/Wait node\n    3. Considered multiple runs can happen for a single workflow\n        and are in higher throughput..\n",
      "autoResize": true,
      "lineHeight": 1.25
    },
