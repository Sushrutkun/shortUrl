    {
      "id": "bRNmHw2pOaxY2xDAnozbN",
      "type": "text",
      "x": 1288.1081205280907,
      "y": 9816.106479652643,
      "width": 930.3792724609375,
      "height": 225,
      "angle": 0,
      "strokeColor": "#e03131",
      "backgroundColor": "transparent",
